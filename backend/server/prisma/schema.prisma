generator client {
  provider     = "prisma-client"
  output       = "../libs/shared/src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String           @id @default(cuid())
  name            String
  email           String?          @unique
  phone           String           @unique
  address         String?
  password        String
  avatar          String?
  wordNumber      Int              @default(0)
  dayNumber       Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  lastLoginAt     DateTime?
  bio             String?
  isTimingTask    Boolean          @default(false)
  timingTaskTime  String           @default("00:00:00")
  courseRecords   CourseRecord[]
  paymentRecords  PaymentRecord[]
  wordBookRecords WordBookRecord[]
  visitors        Visitor[] //User别忘记关联
}

model WordBookRecord {
  id             String      @id @default(cuid())
  wordId         String
  userId         String
  easinessFactor Float       @default(2.5)
  interval       Int         @default(0)
  reps           Int         @default(0)
  nextReviewAt   DateTime    @default(now())
  isMaster       Boolean     @default(false)
  wrongCount     Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  reviewLogs     ReviewLog[]
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  word           WordBook    @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([userId, wordId])
  @@index([nextReviewAt])
}

model ReviewLog {
  id           String         @id @default(cuid())
  recordId     String
  rating       Int
  responseTime Int
  createdAt    DateTime       @default(now())
  record       WordBookRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)

  @@index([recordId])
}

model WordBook {
  id              String           @id @default(cuid())
  word            String
  phonetic        String?
  definition      String?
  translation     String?
  pos             String?
  collins         String?
  oxford          String?
  tag             String?
  bnc             String?
  frq             String?
  exchange        String?
  gk              Boolean?
  zk              Boolean?
  gre             Boolean?
  toefl           Boolean?
  ielts           Boolean?
  cet6            Boolean?
  cet4            Boolean?
  ky              Boolean?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  wordBookRecords WordBookRecord[]

  @@index([word])
  @@index([tag])
  @@index([word, tag])
}

model PaymentRecord {
  id            String         @id @default(cuid())
  userId        String
  tradeNo       String?
  outTradeNo    String         @unique
  amount        Decimal
  subject       String
  body          String
  tradeStatus   TradeStatus    @default(NOT_PAY)
  sendPayTime   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  courseRecords CourseRecord[]
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tradeNo])
}

model CourseRecord {
  id              String         @id @default(cuid())
  userId          String
  courseId        String
  isPurchased     Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  paymentRecordId String?
  course          Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  paymentRecord   PaymentRecord? @relation(fields: [paymentRecordId], references: [id], onDelete: Cascade)
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model Course {
  id            String         @id @default(cuid())
  name          String
  value         String
  description   String?
  teacher       String
  url           String
  price         Decimal
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  courseRecords CourseRecord[]
}

model checkpoint_blobs {
  thread_id     String
  checkpoint_ns String @default("")
  channel       String
  version       String
  type          String
  blob          Bytes?

  @@id([thread_id, checkpoint_ns, channel, version])
  @@index([thread_id])
}

model checkpoint_migrations {
  v Int @id
}

model checkpoint_writes {
  thread_id     String
  checkpoint_ns String  @default("")
  checkpoint_id String
  task_id       String
  idx           Int
  channel       String
  type          String?
  blob          Bytes
  task_path     String  @default("")

  @@id([thread_id, checkpoint_ns, checkpoint_id, task_id, idx])
  @@index([thread_id])
}

model checkpoints {
  thread_id            String
  checkpoint_ns        String  @default("")
  checkpoint_id        String
  parent_checkpoint_id String?
  type                 String?
  checkpoint           Json
  metadata             Json    @default("{}")

  @@id([thread_id, checkpoint_ns, checkpoint_id])
  @@index([thread_id])
}

model composition_history_messages {
  id                          BigInt                      @id @default(autoincrement())
  user_id                     String
  thread_id                   String
  role                        String
  content                     String
  created_at                  DateTime                    @default(now()) @db.Timestamptz(6)
  composition_history_threads composition_history_threads @relation(fields: [user_id, thread_id], references: [user_id, thread_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_composition_history_thread")

  @@index([user_id, thread_id, created_at], map: "idx_composition_history_messages_thread")
}

model composition_history_threads {
  user_id                      String
  thread_id                    String
  session_id                   String?
  topic                        String?
  exam_type                    String?
  task_type                    String?
  last_band_score              Float?
  preview                      String?
  updated_at                   DateTime                       @default(now()) @db.Timestamptz(6)
  composition_history_messages composition_history_messages[]

  @@id([user_id, thread_id])
  @@index([user_id, updated_at(sort: Desc)], map: "idx_composition_history_threads_updated")
}

model normal_history_messages {
  id                     BigInt                 @id @default(autoincrement())
  user_id                String
  thread_id              String
  role                   String
  content                String
  created_at             DateTime               @default(now()) @db.Timestamptz(6)
  normal_history_threads normal_history_threads @relation(fields: [user_id, thread_id], references: [user_id, thread_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_normal_history_thread")

  @@index([user_id, thread_id, created_at], map: "idx_normal_history_messages_thread")
}

model normal_history_threads {
  user_id                 String
  thread_id               String
  session_id              String?
  mode                    String?
  preview                 String?
  updated_at              DateTime                  @default(now()) @db.Timestamptz(6)
  normal_history_messages normal_history_messages[]

  @@id([user_id, thread_id])
  @@index([user_id, updated_at(sort: Desc)], map: "idx_normal_history_threads_updated")
}

model speak_history_messages {
  id                    BigInt                @id @default(autoincrement())
  user_id               String
  thread_id             String
  role                  String
  content               String
  created_at            DateTime              @default(now()) @db.Timestamptz(6)
  speak_history_threads speak_history_threads @relation(fields: [user_id, thread_id], references: [user_id, thread_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_speak_history_thread")

  @@index([user_id, thread_id, created_at], map: "idx_speak_history_messages_thread")
}

model speak_history_threads {
  user_id                String
  thread_id              String
  session_id             String?
  topic                  String?
  preview                String?
  updated_at             DateTime                 @default(now()) @db.Timestamptz(6)
  speak_history_messages speak_history_messages[]

  @@id([user_id, thread_id])
  @@index([user_id, updated_at(sort: Desc)], map: "idx_speak_history_threads_updated")
}

enum TradeStatus {
  NOT_PAY
  WAIT_BUYER_PAY
  TRADE_CLOSED
  TRADE_SUCCESS
  TRADE_FINISHED
}

model Visitor {
  id                 String             @id @default(cuid()) // 访客ID
  anonymousId        String             @unique // 匿名ID
  userId             String? // 用户ID
  user               User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt          DateTime           @default(now()) // 创建时间
  updatedAt          DateTime           @updatedAt // 更新时间
  browser            String? // 浏览器信息
  os                 String? // 操作系统信息
  device             String? // 设备信息
  pageViews          PageView[]
  trackEvents        TrackEvent[]
  performanceEntries PerformanceEntry[]
  errorEntries       ErrorEntry[]

  @@index([userId])
  @@index([anonymousId])
}

//pv表
model PageView {
  id        String   @id @default(cuid()) // pvID
  visitorId String // 访客ID
  visitor   Visitor  @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  url       String // 页面URL
  referrer  String? // 来源URL
  path      String // 页面路径
  createdAt DateTime @default(now()) // 创建时间
  updatedAt DateTime @updatedAt // 更新时间

  @@index([visitorId, createdAt])
  @@index([path, createdAt])
}

//用户行为表
model TrackEvent {
  id        String   @id @default(cuid()) // 行为ID
  visitorId String // 访客ID
  visitor   Visitor  @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  event     String // 事件类型
  payload   Json? // 事件数据
  url       String? // 页面URL
  createdAt DateTime @default(now()) // 创建时间
  updatedAt DateTime @updatedAt // 更新时间

  @@index([visitorId, createdAt])
  @@index([event, createdAt])
}

//性能指标
model PerformanceEntry {
  id        String   @id @default(cuid()) // 性能指标ID
  visitorId String // 访客ID
  visitor   Visitor  @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  fp        Float? // FP
  fcp       Float? // FCP
  lcp       Float? // LCP
  inp       Float? // INP
  cls       Float? // CLS
  createdAt DateTime @default(now()) // 创建时间
  updatedAt DateTime @updatedAt // 更新时间

  @@index([fp, createdAt])
  @@index([fcp, createdAt])
  @@index([lcp, createdAt])
  @@index([inp, createdAt])
  @@index([cls, createdAt])
  @@index([fp, fcp, lcp, inp, cls, createdAt])
}

model ErrorEntry {
  id        String   @id @default(cuid()) // 错误指标ID
  visitorId String // 访客ID
  visitor   Visitor  @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  error     String // 错误类型 js |promise
  message   String? // 错误信息
  stack     String? // 错误堆栈
  url       String? // 页面URL
  createdAt DateTime @default(now()) // 创建时间
  updatedAt DateTime @updatedAt // 更新时间

  @@index([visitorId, createdAt])
  @@index([error, createdAt])
}
